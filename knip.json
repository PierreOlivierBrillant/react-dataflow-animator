{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "tags": ["-lintignore"],
  "workspaces": {
    "packages/core": {
      "entry": ["src/**/*.test.ts", "scripts/*.mjs"],
      "project": ["src/**/*.ts", "scripts/*.mjs"],
      "ignoreDependencies": ["react-icons"]
    },
    "packages/react-dataflow-animator": {
      "entry": [
        "src/index.ts",
        "src/**/*.test.ts",
        "src/**/*.test.tsx",
        "scripts/*.mjs",
        "rollup.dts.config.mjs"
      ],
      "project": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "scripts/*.mjs",
        "scripts/validation-harness/**/*.{ts,tsx}"
      ],
      "ignoreDependencies": ["prismjs"]
    },
    "apps/docs": {
      "entry": [
        "src/pages/**/*.tsx",
        "src/site-content/index.ts",
        "src/theme/**/*.tsx",
        "src/**/*.test.{ts,tsx}"
      ],
      "project": ["src/**/*.ts", "src/**/*.tsx"]
    }
  },
  "ignore": [
    "eslint.config.js",
    "packages/react-dataflow-animator/src/css.d.ts"
  ],
  "ignoreDependencies": [
    "@docusaurus/theme-common",
    "@eslint/js",
    "autoprefixer",
    "eslint-plugin-react-hooks",
    "eslint-plugin-react-refresh",
    "globals",
    "postcss",
    "tailwindcss",
    "typescript-eslint"
  ]
}
