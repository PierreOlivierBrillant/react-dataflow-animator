{
  "name": "react-dataflow-animator",
  "version": "2.0.0",
  "description": "Composant React qui compile une spécification JSON en une animation déterministe et navigable de flux de données (client/serveur/SQL…).",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "react",
    "animation",
    "diagram",
    "dataflow",
    "docusaurus",
    "teaching",
    "visualization"
  ],
  "author": "Pierre-Olivier Brillant",
  "homepage": "https://github.com/PierreOlivierBrillant/react-dataflow-animator",
  "repository": {
    "type": "git",
    "url": "https://github.com/PierreOlivierBrillant/react-dataflow-animator.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/style.css",
    "./schema.json": "./dist/schema.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "generate:schema": "node scripts/generate-schema.mjs",
    "check:schema": "node scripts/check-schema-is-fresh.mjs",
    "build": "npm run generate:schema && tsc -b tsconfig.app.json tsconfig.node.json && vite build && tsc -p tsconfig.dts.json",
    "postbuild": "cp src/schema.generated.json dist/schema.json",
    "dev": "vite build --watch",
    "lint": "eslint src",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "smoke:export": "node scripts/smoke-export.mjs",
    "harness": "vite --config scripts/validation-harness/vite.config.ts",
    "curves": "node scripts/extract-curves.mjs",
    "test:visual": "playwright test"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "prismjs": "^1.30.0",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.12.3",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^26.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ts-json-schema-generator": "^2.9.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^3.2.4"
  }
}
