{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "paths": {
      "@react-dataflow-animator/core/*": ["../core/src/*"]
    },
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true
  },
  // `../core/src/**/*.d.ts`: ambient module declarations (e.g. the Prism
  // components typing) live in the core workspace now. `include` only
  // resolves the ROOT file set for the program — files pulled in transitively
  // via `paths` are added too, but a loose ambient `.d.ts` with no import is
  // never reached that way, so it must be listed explicitly (same reasoning
  // as vite.config.ts's `watch.include`, which isn't additive either).
  "include": ["src", "../core/src/**/*.d.ts"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
