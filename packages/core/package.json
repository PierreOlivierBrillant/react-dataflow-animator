{
  "name": "@react-dataflow-animator/core",
  "version": "0.0.0",
  "private": true,
  "description": "Framework-agnostic core of react-dataflow-animator: spec TypeScript types and the JSON Schema generated from them.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./schema": "./src/schema.ts",
    "./schema.generated.json": "./src/schema.generated.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "generate:schema": "node scripts/generate-schema.mjs",
    "check:schema": "node scripts/check-schema-is-fresh.mjs",
    "lint": "eslint src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.3.0",
    "ts-json-schema-generator": "^2.9.0",
    "vitest": "^3.2.4"
  }
}
