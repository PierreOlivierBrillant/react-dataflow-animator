{
  "name": "@react-dataflow-animator/core",
  "version": "0.0.0",
  "private": true,
  "description": "Framework-agnostic core of react-dataflow-animator: spec TypeScript types and the JSON Schema generated from them.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./schema": "./src/schema.ts",
    "./schema.generated.json": "./src/schema.generated.json",
    "./engine/*": "./src/engine/*.ts",
    "./tex/*": "./src/tex/*.ts",
    "./highlight/*": "./src/highlight/*.ts",
    "./export/*": "./src/export/*.ts",
    "./render/*": "./src/render/*.ts",
    "./dom/*": "./src/dom/*.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "generate:schema": "node scripts/generate-schema.mjs",
    "check:schema": "node scripts/check-schema-is-fresh.mjs",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "prismjs": "^1.30.0"
  },
  "devDependencies": {
    "@types/prismjs": "^1.26.5",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.3.0",
    "ts-json-schema-generator": "^2.9.0",
    "typescript": "~6.0.2",
    "vitest": "^3.2.4"
  }
}
