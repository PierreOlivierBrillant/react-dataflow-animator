{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": false,
    "outDir": "dist",
    "rootDir": "src/lib",
    "types": []
  },
  "include": ["src/lib"],
  "exclude": ["src/lib/**/*.test.ts", "src/lib/**/*.test.tsx"]
}
